<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:SnakeMaui.Models"
             x:Class="SnakeMaui.MainPage"
             Title="Snake">

    <ScrollView>
        <Grid x:Name="RootGrid"
              Padding="24"
              RowDefinitions="Auto,Auto"
              RowSpacing="18"
              MaximumWidthRequest="1120"
              HorizontalOptions="Center"
              BackgroundColor="{AppThemeBinding Light=#F6F8F0, Dark=#101510}">

            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="16">
                <VerticalStackLayout Spacing="2">
                    <Label Text="Snake"
                           FontAttributes="Bold"
                           FontSize="36"
                           TextColor="{AppThemeBinding Light=#15351A, Dark=#F2F7EF}" />
                    <Label Text="MAUI"
                           FontSize="15"
                           TextColor="{AppThemeBinding Light=#5C6B58, Dark=#B9C8B3}" />
                </VerticalStackLayout>

                <Border Grid.Column="1"
                        Padding="16,10"
                        Stroke="#BFD0B9"
                        BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#172017}"
                        StrokeShape="RoundRectangle 8"
                        VerticalOptions="Center">
                    <VerticalStackLayout Spacing="0">
                        <Label Text="Wynik"
                               FontSize="12"
                               TextColor="{AppThemeBinding Light=#5C6B58, Dark=#B9C8B3}" />
                        <Label Text="{Binding CurrentScore}"
                               FontSize="26"
                               FontAttributes="Bold"
                               HorizontalTextAlignment="End"
                               TextColor="{AppThemeBinding Light=#204A24, Dark=#D7F75B}" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <Grid x:Name="ContentGrid"
                  Grid.Row="1"
                  ColumnDefinitions="*,320"
                  ColumnSpacing="20"
                  RowSpacing="20">

                <VerticalStackLayout x:Name="BoardSection"
                                     Spacing="12">
                    <Border x:Name="BoardHost"
                            Padding="12"
                            Stroke="#243423"
                            BackgroundColor="#111812"
                            StrokeShape="RoundRectangle 8"
                            HorizontalOptions="Center">
                        <GraphicsView x:Name="GameCanvas"
                                      WidthRequest="520"
                                      HeightRequest="520"
                                      HorizontalOptions="Center"
                                      VerticalOptions="Center" />
                    </Border>

                    <Label Text="{Binding StatusMessage}"
                           FontSize="16"
                           FontAttributes="Bold"
                           HorizontalTextAlignment="Center"
                           TextColor="{AppThemeBinding Light=#204A24, Dark=#EAF4E5}" />

                    <Grid WidthRequest="260"
                          HorizontalOptions="Center"
                          ColumnDefinitions="*,*,*"
                          RowDefinitions="Auto,Auto,Auto"
                          ColumnSpacing="8"
                          RowSpacing="8">
                        <Button Grid.Row="0"
                                Grid.Column="1"
                                Text="Góra"
                                Command="{Binding ChangeDirectionCommand}"
                                CommandParameter="{x:Static models:Direction.Up}"
                                BackgroundColor="#2E7D32"
                                TextColor="White" />
                        <Button Grid.Row="1"
                                Grid.Column="0"
                                Text="Lewo"
                                Command="{Binding ChangeDirectionCommand}"
                                CommandParameter="{x:Static models:Direction.Left}"
                                BackgroundColor="#2E7D32"
                                TextColor="White" />
                        <Button Grid.Row="1"
                                Grid.Column="2"
                                Text="Prawo"
                                Command="{Binding ChangeDirectionCommand}"
                                CommandParameter="{x:Static models:Direction.Right}"
                                BackgroundColor="#2E7D32"
                                TextColor="White" />
                        <Button Grid.Row="2"
                                Grid.Column="1"
                                Text="Dół"
                                Command="{Binding ChangeDirectionCommand}"
                                CommandParameter="{x:Static models:Direction.Down}"
                                BackgroundColor="#2E7D32"
                                TextColor="White" />
                    </Grid>

                </VerticalStackLayout>

                <Border x:Name="PanelSection"
                        Grid.Column="1"
                        Padding="20"
                        Stroke="#BFD0B9"
                        BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#172017}"
                        StrokeShape="RoundRectangle 8"
                        VerticalOptions="Start">
                    <VerticalStackLayout Spacing="18">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Gracz"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#15351A, Dark=#F2F7EF}" />
                            <Entry Text="{Binding PlayerName, Mode=TwoWay}"
                                   Placeholder="Nazwa gracza"
                                   MaxLength="24" />
                        </VerticalStackLayout>

                        <Button Text="{Binding StartButtonText}"
                                Command="{Binding StartCommand}"
                                BackgroundColor="#D7F75B"
                                TextColor="#15351A"
                                FontAttributes="Bold" />

                        <Button Text="{Binding PauseButtonText}"
                                Command="{Binding PauseCommand}"
                                IsEnabled="{Binding IsPauseEnabled}"
                                BackgroundColor="#EDE6D5"
                                TextColor="#15351A" />

                        <BoxView HeightRequest="1"
                                 BackgroundColor="{AppThemeBinding Light=#E2E8D8, Dark=#2B382B}" />

                        <VerticalStackLayout Spacing="10">
                            <Label Text="Najlepsze wyniki"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#15351A, Dark=#F2F7EF}" />

                            <CollectionView ItemsSource="{Binding HighScores}"
                                            SelectionMode="None"
                                            HeightRequest="310">
                                <CollectionView.EmptyView>
                                    <Label Text="Brak zapisanych wyników"
                                           TextColor="{AppThemeBinding Light=#5C6B58, Dark=#B9C8B3}" />
                                </CollectionView.EmptyView>
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="models:ScoreEntry">
                                        <Grid Padding="0,9"
                                              ColumnDefinitions="Auto,*,Auto"
                                              RowDefinitions="Auto,Auto"
                                              ColumnSpacing="12">
                                            <Label Text="{Binding Score}"
                                                   FontSize="20"
                                                   FontAttributes="Bold"
                                                   TextColor="{AppThemeBinding Light=#204A24, Dark=#D7F75B}" />
                                            <Label Grid.Column="1"
                                                   Text="{Binding PlayerName}"
                                                   FontAttributes="Bold"
                                                   LineBreakMode="TailTruncation"
                                                   TextColor="{AppThemeBinding Light=#15351A, Dark=#F2F7EF}" />
                                            <Label Grid.Column="1"
                                                   Grid.Row="1"
                                                   Text="{Binding PlayedAtDisplay}"
                                                   FontSize="12"
                                                   TextColor="{AppThemeBinding Light=#5C6B58, Dark=#B9C8B3}" />
                                            <BoxView Grid.ColumnSpan="3"
                                                     Grid.Row="1"
                                                     HeightRequest="1"
                                                     Margin="0,28,0,0"
                                                     BackgroundColor="{AppThemeBinding Light=#E2E8D8, Dark=#2B382B}" />
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>
            </Grid>
        </Grid>
    </ScrollView>
</ContentPage>
