<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:SnakeMaui.Models"
             x:Class="SnakeMaui.MainPage"
             Title="Wonsz">

    <Grid x:Name="RootGrid"
          Padding="20"
          RowDefinitions="Auto,*"
          RowSpacing="12"
          MaximumWidthRequest="1120"
          HorizontalOptions="Center"
          VerticalOptions="Fill"
          BackgroundColor="{AppThemeBinding Light=#F6F8F0, Dark=#101510}">

        <Grid ColumnDefinitions="*,Auto"
              ColumnSpacing="12">
            <Label Text="Wonsz"
                   VerticalTextAlignment="Center"
                   FontAttributes="Bold"
                   FontSize="40"
                   TextColor="{AppThemeBinding Light=#15351A, Dark=#F2F7EF}" />

            <Border Grid.Column="1"
                    Padding="14,8"
                    Stroke="#BFD0B9"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#172017}"
                    StrokeShape="RoundRectangle 8"
                    VerticalOptions="Center">
                <VerticalStackLayout Spacing="0">
                    <Label Text="Wynik"
                           FontSize="12"
                           TextColor="{AppThemeBinding Light=#5C6B58, Dark=#B9C8B3}" />
                    <Label Text="{Binding CurrentScore}"
                           FontSize="24"
                           FontAttributes="Bold"
                           HorizontalTextAlignment="End"
                           TextColor="{AppThemeBinding Light=#204A24, Dark=#D7F75B}" />
                </VerticalStackLayout>
            </Border>
        </Grid>

        <Grid x:Name="ContentGrid"
              Grid.Row="1"
              ColumnDefinitions="*,320"
              ColumnSpacing="20"
              RowSpacing="12">

            <VerticalStackLayout x:Name="BoardSection"
                                 Spacing="8">
                <Border x:Name="BoardHost"
                        Padding="12"
                        Stroke="#243423"
                        BackgroundColor="#111812"
                        StrokeShape="RoundRectangle 8"
                        HorizontalOptions="Center">
                    <GraphicsView x:Name="GameCanvas"
                                  WidthRequest="520"
                                  HeightRequest="520"
                                  HorizontalOptions="Center"
                                  VerticalOptions="Center" />
                </Border>

                <Label Text="{Binding StatusMessage}"
                       FontSize="15"
                       FontAttributes="Bold"
                       HorizontalTextAlignment="Center"
                       TextColor="{AppThemeBinding Light=#204A24, Dark=#EAF4E5}" />
            </VerticalStackLayout>

            <ScrollView x:Name="PanelScrollView"
                        Grid.Column="1"
                        Orientation="Vertical">
                <Border x:Name="PanelSection"
                        Padding="14"
                        Stroke="#BFD0B9"
                        BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#172017}"
                        StrokeShape="RoundRectangle 8"
                        VerticalOptions="Start">
                    <VerticalStackLayout Spacing="10">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Gracz"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#15351A, Dark=#F2F7EF}" />
                            <Entry Text="{Binding PlayerName, Mode=TwoWay}"
                                   Placeholder="Nazwa gracza"
                                   MaxLength="24" />
                        </VerticalStackLayout>

                        <Button Text="{Binding StartButtonText}"
                                Command="{Binding StartCommand}"
                                BackgroundColor="#D7F75B"
                                TextColor="#15351A"
                                FontAttributes="Bold" />

                        <Button Text="{Binding PauseButtonText}"
                                Command="{Binding PauseCommand}"
                                IsEnabled="{Binding IsPauseEnabled}"
                                BackgroundColor="#EDE6D5"
                                TextColor="#15351A" />

                        <BoxView HeightRequest="1"
                                 BackgroundColor="{AppThemeBinding Light=#E2E8D8, Dark=#2B382B}" />

                        <VerticalStackLayout Spacing="6">
                            <Label Text="Najlepsze wyniki"
                                   FontSize="17"
                                   FontAttributes="Bold"
                                   TextColor="{AppThemeBinding Light=#15351A, Dark=#F2F7EF}" />

                            <CollectionView ItemsSource="{Binding HighScores}"
                                            SelectionMode="None"
                                            HeightRequest="130">
                                <CollectionView.EmptyView>
                                    <Label Text="Brak zapisanych wynikow"
                                           TextColor="{AppThemeBinding Light=#5C6B58, Dark=#B9C8B3}" />
                                </CollectionView.EmptyView>
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="models:ScoreEntry">
                                        <Grid Padding="0,7"
                                              ColumnDefinitions="Auto,*,Auto"
                                              RowDefinitions="Auto,Auto"
                                              ColumnSpacing="10">
                                            <Label Text="{Binding Score}"
                                                   FontSize="18"
                                                   FontAttributes="Bold"
                                                   TextColor="{AppThemeBinding Light=#204A24, Dark=#D7F75B}" />
                                            <Label Grid.Column="1"
                                                   Text="{Binding PlayerName}"
                                                   FontAttributes="Bold"
                                                   LineBreakMode="TailTruncation"
                                                   TextColor="{AppThemeBinding Light=#15351A, Dark=#F2F7EF}" />
                                            <Label Grid.Column="1"
                                                   Grid.Row="1"
                                                   Text="{Binding PlayedAtDisplay}"
                                                   FontSize="12"
                                                   TextColor="{AppThemeBinding Light=#5C6B58, Dark=#B9C8B3}" />
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>
            </ScrollView>
        </Grid>
    </Grid>
</ContentPage>
